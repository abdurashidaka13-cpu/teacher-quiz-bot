# Telegram Bot Token (t.me/BotFather dan olinadi)
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# PostgreSQL (Neon.tech yoki Supabase) asinxron bog'lanish URL manzili
# DIQQAT: Hayotiy loyihada postgresql+asyncpg:// bilan boshlanishi shart!
DATABASE_URL=postgresql+asyncpg://postgres:password@ep-cool-water-12345.us-east-2.aws.neon.tech/neondb

# Super Admin Telegram ID raqamlari (vergul bilan ajratilgan holda yoziladi)
ADMIN_IDS=123456789,987654321

# Webhook orqali ishga tushirish sozlamalari (Render.com manzili)
# Agar botni webhook emas, Polling rejimida sinamoqchi bo'lsangiz bo'sh qoldiring
WEBHOOK_URL=https://teacher-quiz-bot.onrender.com
WEBHOOK_SECRET=MySuperStrongSecretToken123!

# Server porti (Render.com avtomat PORT o'zgaruvchisini beradi)
PORT=8000

# PostgreSQL xavfsiz ulanish (Render.com/Neon kabi serverlarda SSL kerak bo'ladi)
# Mahalliy (Localhost) da ishlatganda false qiling
DATABASE_SSL=true

# Redis (FSM state saqlash uchun). Agar ulanmasa, MemoryStorage ishlaydi
# REDIS_URL=redis://default:password@hostname:port
